# Azure AI Search (Foundry IQ) — from IQ Series deployment outputs
SEARCH_ENDPOINT=https://YOUR-SEARCH-SERVICE.search.windows.net
SEARCH_API_KEY=your-search-query-or-admin-key

# Foundry IQ resource names (defaults match setup script)
BOARD_INDEX_NAME=board-decisions
KNOWLEDGE_BASE_NAME=board-decisions-kb
BOARD_KNOWLEDGE_SOURCE=board-decisions-source

# Azure OpenAI — from IQ Series deployment outputs
AOAI_ENDPOINT=https://YOUR-OPENAI-RESOURCE.openai.azure.com
AOAI_API_KEY=your-openai-key
AOAI_GPT_DEPLOYMENT=gpt-4o-mini
AOAI_GPT_MODEL=gpt-4o-mini
AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AOAI_EMBEDDING_MODEL=text-embedding-3-large

# API server
PORT=3001
